{
  "name": "rel-reverser",
  "displayName": "PlantUML Relationship Reverser",
  "description": "Relationship reverser for PlantUML",
  "version": "0.1.2",
  "publisher": "eins-llc",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/yiwaki/rel-reverser" },
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "plantuml-helper.reverseRelation",
        "title": "PlantUML: Reverse Relationship"
      },
      {
        "command": "plantuml-helper.swapElements",
        "title": "PlantUML: Swap Elements (Keep Relationship)"
      }
    ],
    "keybindings": [
      {
        "command": "plantuml-helper.reverseRelation",
        "key": "ctrl+shift+/",
        "mac": "cmd+shift+/",
        "when": "editorTextFocus && editorLangId == plantuml"
      },
      {
        "command": "plantuml-helper.swapElements",
        "key": "ctrl+shift+alt+/",
        "when": "editorTextFocus && editorLangId == plantuml"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.115.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "volta": {
    "node": "24.14.1"
  }
}
